{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "qcut",
  "version": "0.1.0",
  "identifier": "moe.qcut.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "qcut - Video Editor",
        "width": 1280,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost; media-src 'self' asset: https://asset.localhost; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost asset: https://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["$DOCUMENT/**", "$HOME/**", "$DESKTOP/**", "$DOWNLOAD/**", "$APP_DATA/**", "$APP_CONFIG/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
